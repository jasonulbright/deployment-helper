<Controls:MetroWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    Title="Deployment Helper"
    Width="1280" Height="720"
    MinWidth="960" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    TitleCharacterCasing="Normal"
    GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    NonActiveGlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    BorderThickness="1"
    ShowIconOnTitleBar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Steel.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Sidebar button template: shade-lift on Pressed instead of the MahApps
                 Square default (which inverts colors via VSM and renders white text
                 invisible on the dark-theme sidebar). Foreground stays White;
                 #3A3A3A reads correctly under either theme during the brief press.
                 See reference_srl_wpf_brand.md S11. -->
            <ControlTemplate x:Key="SidebarButtonTemplate" TargetType="Button">
                <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Margin="{TemplateBinding Padding}"
                                      RecognizesAccessKey="True"
                                      SnapsToDevicePixels="True"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Bd" Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="#3A3A3A"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style x:Key="WorkflowButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="Margin" Value="8,3,8,3"/>
                <Setter Property="Padding" Value="12,0,12,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Controls:ControlsHelper.ContentCharacterCasing" Value="Normal"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#1E1E1E"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="#555555"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="OptionsButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="Margin" Value="8,3,8,3"/>
                <Setter Property="Padding" Value="12,0,12,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Controls:ControlsHelper.ContentCharacterCasing" Value="Normal"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#1E1E1E"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="#555555"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <!-- Section header: Gray1 is the only theme-adaptive MahApps greyscale
                 brush. Gray2 is static #7F7F7F and fails WCAG AA. See
                 reference_srl_wpf_brand.md. -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Gray1}"/>
                <Setter Property="Margin" Value="12,16,0,6"/>
            </Style>

            <Style x:Key="FormLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
            </Style>

            <Style x:Key="BrowseButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Height" Value="28"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
                <Setter Property="Controls:ControlsHelper.ContentCharacterCasing" Value="Normal"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- Validation glyph: color stays at ThemeForeground per brand rule
                 (feedback_no_red_green_in_brand.md). State is carried by the
                 glyph shape alone (checkmark / ballot-x / horizontal-ellipsis),
                 never by Foreground. -->
            <Style x:Key="CheckGlyphStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Width" Value="20"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="CheckLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="8,0,0,0"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════ -->
        <!-- LEFT SIDEBAR                            -->
        <!-- ═══════════════════════════════════════ -->
        <Border Grid.Column="0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="14,14,14,0">
                    <TextBlock x:Name="txtAppTitle" Text="Deployment Helper" FontSize="20" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,14">
                    <Separator Margin="0,8,0,10"/>
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="txtThemeLabel" Text="Dark Theme"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="12"/>
                        <Controls:ToggleSwitch x:Name="toggleTheme"
                                               DockPanel.Dock="Right"
                                               IsOn="True"
                                               OnContent="" OffContent=""
                                               Margin="0,0,0,0"
                                               MinWidth="0"
                                               ToolTip="Toggle dark / light theme"/>
                    </DockPanel>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel>

                        <Button x:Name="btnApps"            Content="Apps"                   Style="{StaticResource WorkflowButtonStyle}"
                                ToolTip="Deploy an application to a device collection"/>
                        <Button x:Name="btnPackages"        Content="Packages"               Style="{StaticResource WorkflowButtonStyle}"
                                ToolTip="Deploy a classic package and program to a device collection"/>
                        <Button x:Name="btnTaskSequences"   Content="Task Sequences"         Style="{StaticResource WorkflowButtonStyle}"
                                ToolTip="Deploy a task sequence to a device collection"/>
                        <Button x:Name="btnSUG"             Content="Software Update Groups" Style="{StaticResource WorkflowButtonStyle}"
                                ToolTip="Deploy a software update group to a device collection"/>

                        <Button x:Name="btnOptions"         Content="Options"                Style="{StaticResource OptionsButtonStyle}"
                                Margin="8,16,8,3"
                                ToolTip="Connection, Logging, History, Templates, About"/>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Sidebar / content separator -->
        <Border Grid.Column="1" Background="{DynamicResource MahApps.Brushes.Gray8}"/>

        <!-- ═══════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                       -->
        <!-- ═══════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Module header + Apply Template -->
            <DockPanel Grid.Row="0" Margin="16,14,16,6" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="Apply template:" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cboApplyTemplate" Width="220" Height="28" FontSize="12" VerticalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="txtModuleHeader" Text="Apps Deployment" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtModuleSubheader"
                               Text="Select an application and a device collection, then configure the deployment."
                               FontSize="12"
                               Foreground="{DynamicResource MahApps.Brushes.Gray1}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>

            <!-- Unified form pane. Scrollable fields + fixed action button row. -->
            <Grid Grid.Row="1" x:Name="formPane" Margin="16,6,16,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Shared form fields (visible for all types) -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Target name (label changes per type) -->
                        <TextBlock x:Name="lblTargetName" Grid.Row="0" Grid.Column="0" Text="Application:" Style="{StaticResource FormLabelStyle}" Margin="0,8,12,8"/>
                        <TextBox x:Name="txtTargetName" Grid.Row="0" Grid.Column="1" FontSize="12" Height="28" VerticalContentAlignment="Center" Margin="0,8,0,8"
                                 Controls:TextBoxHelper.Watermark="e.g. 7-Zip 26.00"/>
                        <Button x:Name="btnBrowseTarget" Grid.Row="0" Grid.Column="2" Content="Browse..." Style="{StaticResource BrowseButtonStyle}" Margin="8,8,0,8"
                                ToolTip="Pick an application, package, task sequence, or SUG from MECM"/>

                        <!-- Program (Packages type only) -->
                        <TextBlock x:Name="lblProgram" Grid.Row="1" Grid.Column="0" Text="Program:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8" Visibility="Collapsed"/>
                        <ComboBox  x:Name="cboProgram" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   FontSize="12" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,8"
                                   Visibility="Collapsed"/>

                        <!-- Collection -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Collection:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8"/>
                        <TextBox x:Name="txtCollection" Grid.Row="2" Grid.Column="1" FontSize="12" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,8"
                                 Controls:TextBoxHelper.Watermark="Device collection name (e.g. Workstations - Pilot)"/>
                        <Button x:Name="btnBrowseCollection" Grid.Row="2" Grid.Column="2" Content="Browse..." Style="{StaticResource BrowseButtonStyle}" Margin="8,0,0,8"
                                ToolTip="Pick a device collection from MECM"/>

                        <!-- Purpose -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Purpose:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="radAvailable" Content="Available" GroupName="Purpose" IsChecked="True" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <RadioButton x:Name="radRequired"  Content="Required"  GroupName="Purpose" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Available datetime -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Available:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8"/>
                        <Controls:DateTimePicker x:Name="dtpAvailable" Grid.Row="4" Grid.Column="1" Width="240" HorizontalAlignment="Left"
                                                 FontSize="12" Height="28" Margin="0,0,0,8"/>

                        <!-- Deadline datetime (only when Required) -->
                        <TextBlock x:Name="lblDeadline" Grid.Row="5" Grid.Column="0" Text="Deadline:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8"/>
                        <Controls:DateTimePicker x:Name="dtpDeadline" Grid.Row="5" Grid.Column="1" Width="240" HorizontalAlignment="Left"
                                                 FontSize="12" Height="28" IsEnabled="False" Margin="0,0,0,8"/>

                        <!-- Notification (Apps type only; packages don't use UserNotification) -->
                        <TextBlock x:Name="lblNotification" Grid.Row="6" Grid.Column="0" Text="Notification:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8"/>
                        <ComboBox x:Name="cboNotification" Grid.Row="6" Grid.Column="1" Width="280" HorizontalAlignment="Left"
                                  FontSize="12" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,8">
                            <ComboBoxItem Content="Display All" IsSelected="True" Tag="DisplayAll"/>
                            <ComboBoxItem Content="Display in Software Center Only" Tag="DisplaySoftwareCenterOnly"/>
                            <ComboBoxItem Content="Hide All" Tag="HideAll"/>
                        </ComboBox>

                        <!-- Time basis -->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Time basis:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8"/>
                        <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="radLocalTime" Content="Local time" GroupName="TimeBasis" IsChecked="True" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <RadioButton x:Name="radUtc"       Content="UTC"        GroupName="TimeBasis" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Distribute content (Apps/Packages/TS only; SUG distributes via SUDP separately) -->
                        <TextBlock x:Name="lblDistribute" Grid.Row="8" Grid.Column="0" Text="Distribute to:" Style="{StaticResource FormLabelStyle}" Margin="0,0,12,8" Visibility="Collapsed"/>
                        <StackPanel x:Name="pnlDistribute" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                            <Button x:Name="btnDPPicker" Content="Select DP groups..." MinWidth="220" Height="28" HorizontalContentAlignment="Left" Padding="10,0,10,0"
                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                    Controls:ControlsHelper.ContentCharacterCasing="Normal"
                                    ToolTip="Pick distribution point groups for content distribution"/>
                            <Button x:Name="btnDistributeContent" Content="Distribute content" MinWidth="140" Height="28" Margin="8,0,0,0"
                                    Style="{DynamicResource MahApps.Styles.Button.Square}"
                                    Controls:ControlsHelper.ContentCharacterCasing="Normal"
                                    ToolTip="Send content to the selected DP groups now"/>
                        </StackPanel>

                        <!-- Required-only: override service window + reboot outside -->
                        <StackPanel x:Name="pnlRequiredOptions" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,0,0,8" Visibility="Collapsed">
                            <CheckBox x:Name="chkOverrideSW"   Content="Override maintenance window"    FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkRebootOutSW"  Content="Reboot outside maintenance window" FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkMetered"      Content="Allow install on metered network" FontSize="12" Margin="0,0,0,0"/>
                        </StackPanel>

                        <!-- Packages-only options: network behavior + rerun + Required-extras. -->
                        <!-- Self-contained on Grid.Row=9 so no overlap with pnlRequiredOptions   -->
                        <!-- (which is now Apps-only).                                            -->
                        <StackPanel x:Name="pnlPackageOptions" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,0,0,8" Visibility="Collapsed">
                            <CheckBox x:Name="chkPkgOverrideSW"   Content="Override maintenance window (install outside MW)" FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkPkgRebootOutSW"  Content="Allow restart outside maintenance window"         FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkPkgMetered"      Content="Use metered network"                              FontSize="12" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Fast network:" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox  Grid.Column="1" x:Name="cboPkgFastNetwork" FontSize="12" Height="26">
                                    <ComboBoxItem Tag="DownloadContentFromDistributionPointAndRunLocally" Content="Download content from DP and run locally" IsSelected="True"/>
                                    <ComboBoxItem Tag="RunProgramFromDistributionPoint"                    Content="Run program from DP"/>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Slow network:" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox  Grid.Column="1" x:Name="cboPkgSlowNetwork" FontSize="12" Height="26">
                                    <ComboBoxItem Tag="DoNotRunProgram"                                 Content="Do not run program" IsSelected="True"/>
                                    <ComboBoxItem Tag="DownloadContentFromDistributionPointAndLocally"  Content="Download content from DP and run locally"/>
                                    <ComboBoxItem Tag="RunProgramFromDistributionPoint"                 Content="Run program from DP"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rerun behavior:" FontSize="12" VerticalAlignment="Center"/>
                                <ComboBox  Grid.Column="1" x:Name="cboPkgRerun" FontSize="12" Height="26">
                                    <ComboBoxItem Tag="NeverRerunDeployedProgram"         Content="Never rerun deployed program" IsSelected="True"/>
                                    <ComboBoxItem Tag="AlwaysRerunProgram"                Content="Always rerun program"/>
                                    <ComboBoxItem Tag="RerunIfFailedPreviousAttempt"      Content="Rerun if failed previous attempt"/>
                                    <ComboBoxItem Tag="RerunIfSucceededOnPreviousAttempt" Content="Rerun if succeeded on previous attempt"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <!-- Task Sequence-only options -->
                        <StackPanel x:Name="pnlTaskSequenceOptions" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,0,0,8" Visibility="Collapsed">
                            <CheckBox x:Name="chkTsOverrideSW"   Content="Override maintenance window (install outside MW)" FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkTsRebootOutSW"  Content="Allow restart outside maintenance window"         FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkTsMetered"      Content="Use metered network"                              FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkShowProgress"   Content="Show task sequence progress on client" FontSize="12" Margin="0,0,0,0" IsChecked="True"/>
                        </StackPanel>

                        <!-- SUG-only options -->
                        <StackPanel x:Name="pnlSUGOptions" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,0,0,8" Visibility="Collapsed">
                            <CheckBox x:Name="chkSugOverrideSW"   Content="Override maintenance window (install outside MW)" FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkSugAllowRestart" Content="Allow restart outside maintenance window"         FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkSugMetered"      Content="Use metered network"                              FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkMSFallback"       Content="Fall back to Microsoft Update if no DP has content" FontSize="12" Margin="0,0,0,4"/>
                            <CheckBox x:Name="chkBoundaryFallback" Content="Allow fallback to neighbor boundary groups" FontSize="12" Margin="0,0,0,4" IsChecked="True"/>
                            <CheckBox x:Name="chkFullScan"         Content="Require post-reboot full scan" FontSize="12" Margin="0,0,0,0" IsChecked="True"/>
                        </StackPanel>
                    </Grid>

                    <!-- Validation panel -->
                    <TextBlock Text="VALIDATION" Style="{StaticResource SectionHeaderStyle}" Margin="0,16,0,6"/>
                    <Border BorderBrush="{DynamicResource MahApps.Brushes.Gray8}" BorderThickness="0,1,0,1" Padding="8,10,8,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="glyphCheck1" Text="&#x22EF;" Style="{StaticResource CheckGlyphStyle}"/>
                                <TextBlock x:Name="lblCheck1"   Text="Application exists in MECM"             Style="{StaticResource CheckLabelStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="glyphCheck2" Text="&#x22EF;" Style="{StaticResource CheckGlyphStyle}"/>
                                <TextBlock x:Name="lblCheck2"   Text="Content distributed to DPs"             Style="{StaticResource CheckLabelStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="glyphCheck3" Text="&#x22EF;" Style="{StaticResource CheckGlyphStyle}"/>
                                <TextBlock x:Name="lblCheck3"   Text="Collection valid (device, not user)"    Style="{StaticResource CheckLabelStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="glyphCheck4" Text="&#x22EF;" Style="{StaticResource CheckGlyphStyle}"/>
                                <TextBlock x:Name="lblCheck4"   Text="Collection safe (not SMS000*)"          Style="{StaticResource CheckLabelStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="glyphCheck5" Text="&#x22EF;" Style="{StaticResource CheckGlyphStyle}"/>
                                <TextBlock x:Name="lblCheck5"   Text="No duplicate deployment"                Style="{StaticResource CheckLabelStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>

                <!-- Action buttons (fixed at bottom, outside scrollviewer) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,4">
                    <Button x:Name="btnValidate" Content="Validate" MinWidth="110" Height="32" Margin="0,0,8,0"
                            Style="{DynamicResource MahApps.Styles.Button.Square}"
                            Controls:ControlsHelper.ContentCharacterCasing="Normal"
                            ToolTip="Check all fields against MECM and confirm the deployment is ready"/>
                    <Button x:Name="btnDeploy"   Content="Deploy"   MinWidth="110" Height="32" Visibility="Collapsed"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                            Controls:ControlsHelper.ContentCharacterCasing="Normal"
                            ToolTip="Create the deployment in MECM"/>
                </StackPanel>
            </Grid>

            <!-- Resizable splitter -->
            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource MahApps.Brushes.Gray8}"
                          ResizeDirection="Rows"/>

            <!-- Log output drawer -->
            <Border Grid.Row="3">
                <DockPanel>
                    <TextBlock x:Name="lblLogOutput" DockPanel.Dock="Top" Text="LOG OUTPUT"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="8,6,0,4"/>
                    <TextBox x:Name="txtLog"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="11"
                             BorderThickness="0"
                             Margin="4,0,4,4"/>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="4" Padding="8,4,8,4"
                    Background="{DynamicResource MahApps.Brushes.Gray10}">
                <TextBlock x:Name="txtStatus" Text="Ready." FontSize="11"/>
            </Border>
        </Grid>
    </Grid>

</Controls:MetroWindow>
